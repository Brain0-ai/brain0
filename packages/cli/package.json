{
  "name": "brain0",
  "version": "0.1.0",
  "description": "brain0 \u2014 the black box for AI-written code: `npx brain0 up` on any repo",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "brain0": "./bin/brain0.js"
  },
  "files": [
