    "lint": "node --check bin/brain0.js && node --check src/lib.mjs",
    "test": "node --test test/*.test.mjs"
  },
  "devDependencies": {
    "esbuild": "^0.24.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Brain0-ai/brain0.git",
